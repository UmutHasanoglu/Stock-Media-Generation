{
  "schedule": {
    "timezone": "Europe/Istanbul",
    "local_time": "10:00",
    "github_actions_cron_utc": "0 7 * * *"
  },
  "batch": {
    "concepts_per_day": 5,
    "images_per_concept": 4,
    "target_final_images_per_day": 20,
    "output_root": "generated",
    "approval_folder_name": "approved"
  },
  "models": {
    "research_model": "gpt-4.1-mini",
    "metadata_model": "gpt-4.1-mini",
    "image_model": "gemini-3.1-flash-image",
    "review_model": "gpt-4.1-mini"
  },
  "stock_rules": {
    "primary_marketplace": "Adobe Stock",
    "allow_editorial": false,
    "allow_real_people": false,
    "allow_brands_or_logos": false,
    "allow_public_figures": false,
    "require_commercial_stock_safe_concepts": true
  },
  "notifications": {
    "channel": "email",
    "events": [
      "final_batch_ready_alert"
    ]
  },
  "image_output": {
    "format": "AUTO",
    "extension": "auto",
    "image_size": "4K",
    "allowed_extensions": [
      ".png",
      ".jpg",
      ".jpeg",
      ".webp"
    ],
    "direct_from_model": true,
    "resize_after_generation": false
  },
  "approval": {
    "mode": "openai_auto_review",
    "human_in_the_loop": false,
    "approved_folder_name": "approved"
  }
}
